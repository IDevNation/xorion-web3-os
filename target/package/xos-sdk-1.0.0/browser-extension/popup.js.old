// XOS Multi-Chain Wallet Logic v3.0
var wallets = [];
var currentWalletId = null;
var currentNetwork = 'xos-main';

// Network Config
var networks = {
  'xos-main': { name: 'XOS Mainnet', symbol: 'XOS', color: '#667eea' },
  'xos-test': { name: 'XOS Testnet', symbol: 'tXOS', color: '#28a745' },
  'eth-main': { name: 'Ethereum Main', symbol: 'ETH', color: '#627eea' },
  'bsc-main': { name: 'BSC Mainnet', symbol: 'BNB', color: '#f0b90b' }
};

function getEl(id) { return document.getElementById(id); }

function saveData() {
  var theme = document.documentElement.getAttribute('data-theme');
  chrome.storage.local.set({ 
    wallets: wallets, 
    currentWalletId: currentWalletId, 
    currentNetwork: currentNetwork,
    theme: theme 
  });
}

function loadData() {
  chrome.storage.local.get(['wallets', 'currentWalletId', 'currentNetwork', 'theme'], function(res) {
    if (res.theme === 'dark') toggleTheme(true);
    if (res.currentNetwork) currentNetwork = res.currentNetwork;
    getEl('network-selector').value = currentNetwork;
    updateNetworkUI();

    if (res.wallets && res.wallets.length > 0) {
      wallets = res.wallets;
      currentWalletId = res.currentWalletId || wallets[0].id;
      showScreen('dashboard-screen');
      updateDashboard();
    } else {
      showScreen('welcome-screen');
    }
  });
}

document.addEventListener('DOMContentLoaded', function() {
  loadData();

  // Listeners
  getEl('theme-toggle').onclick = function() { toggleTheme(); };
  getEl('network-selector').onchange = function(e) { 
    currentNetwork = e.target.value; 
    updateNetworkUI(); 
    updateDashboard(); 
    saveData(); 
  };
  getEl('btn-create').onclick = function() { generateSeed(); showScreen('create-screen'); };
  getEl('btn-import').onclick = function() { showScreen('import-screen'); };
  getEl('btn-back-create').onclick = function() { showScreen('welcome-screen'); };
  getEl('btn-back-import').onclick = function() { showScreen('welcome-screen'); };
  getEl('btn-save-new').onclick = createWallet;
  getEl('btn-save-import').onclick = importWallet;
  getEl('btn-lock').onclick = function() { currentWalletId = null; saveData(); showScreen('welcome-screen'); };
  getEl('btn-copy').onclick = copyAddress;
  getEl('btn-send').onclick = sendTransaction;
  getEl('btn-receive').onclick = showReceiveScreen;
  getEl('btn-back-receive').onclick = function() { showScreen('dashboard-screen'); };
  getEl('btn-copy-receive').onclick = copyReceiveAddress;
  getEl('btn-new-wallet').onclick = function() { generateSeed(); showScreen('create-screen'); };
  getEl('btn-delete-wallet').onclick = deleteWallet;
  getEl('wallet-selector').onchange = function(e) { currentWalletId = e.target.value; saveData(); updateDashboard(); };
});

function toggleTheme(forceDark) {
  var html = document.documentElement;
  var isDark = (forceDark !== undefined) ? forceDark : (html.getAttribute('data-theme') !== 'dark');
  html.setAttribute('data-theme', isDark ? 'dark' : 'light');
  getEl('theme-toggle').innerText = isDark ? '☀️' : '🌙';
  if (forceDark === undefined) saveData();
}

function showScreen(id) {
  var screens = document.querySelectorAll('.screen');
  for (var i = 0; i < screens.length; i++) screens[i].classList.remove('active');
  getEl(id).classList.add('active');
  
  // Clear QR if leaving receive screen
  if (id !== 'receive-screen') {
    var qrDiv = getEl('qrcode');
    if(qrDiv) qrDiv.innerHTML = '';
  }
}

function updateNetworkUI() {
  var net = networks[currentNetwork];
  getEl('network-name').innerText = net.name;
  getEl('token-symbol').innerText = net.symbol;
  getEl('net-history').innerText = net.symbol;
  
  // Color status
  var status = getEl('net-status');
  status.style.background = net.color;
  status.innerText = 'Active';
}

function generateSeed() {
  var words = ['abandon','ability','able','about','above','absent','absorb','abstract','absurd','abuse','access','accident','account','achieve','acid','acoustic','acquire','across','act','action','actor','actress','actual','adapt','add','addict','address','adjust','admit','adult','advance','advice','aerobic','affair','afford','afraid','again','age','agent','agree','ahead','aim','air','airport','aisle','alarm','album','alcohol','alert','alien','all','alley','allow','almost','alone','alpha','already','also','alter','always','amateur','amazing','among','amount','amused','analyst','anchor','ancient','anger','angle','angry','animal','ankle','announce','annual','another','answer','antenna','antique','anxiety','any','apart','apology','appear','apple','approve','april','arch','arctic','area','arena','argue','arm','armed','armor','army','around','arrange','arrest','arrive','arrow','art','artefact','artist','artwork','ask','aspect','assault','asset','assist','assume','asthma','athlete','atom','attack','attend','attitude','attract','auction','audit','august','aunt','author','auto','autumn','average','avocado','avoid','awake','aware','away','awesome','awful','awkward','axis'];
  var arr = [];
  for (var i = 0; i < 12; i++) arr.push(words[Math.floor(Math.random() * words.length)]);
  var seedStr = arr.join(' ');
  getEl('seed-display').innerText = seedStr;
  return seedStr;
}

function getWalletBalances(wallet) {
  // Initialize balances for all networks if not exist
  if (!wallet.balances) {
    wallet.balances = {};
    for (var net in networks) {
      wallet.balances[net] = 1000.00; // Default demo balance
    }
  }
  // Initialize TXs per network if not exist
  if (!wallet.txsByNet) {
    wallet.txsByNet = {};
    for (var net in networks) wallet.txsByNet[net] = [];
  }
  return wallet.balances[currentNetwork] || 0;
}

function createWallet() {
  var p1 = getEl('new-pass').value;
  var p2 = getEl('confirm-pass').value;
  if (p1 !== p2 || p1.length < 4) { alert('Password mismatch or too short!'); return; }
  
  var seed = getEl('seed-display').innerText;
  var baseAddr = 'XOS' + Math.random().toString(36).substring(2, 10).toUpperCase();
  
  // Simulate different addresses for different chains (just prefix change for demo)
  var newWallet = {
    id: Date.now().toString(),
    name: 'Wallet ' + (wallets.length + 1),
    baseSeed: seed,
    addresses: {
      'xos-main': baseAddr,
      'xos-test': 't' + baseAddr,
      'eth-main': '0x' + baseAddr.toLowerCase(),
      'bsc-main': '0x' + baseAddr.toLowerCase()
    },
    balances: {}, // Will be initialized by getWalletBalances
    txsByNet: {}  // Will be initialized by getWalletBalances
  };
  
  // Init balances
  getWalletBalances(newWallet); 

  wallets.push(newWallet);
  currentWalletId = newWallet.id;
  saveData();
  updateDashboard();
  showScreen('dashboard-screen');
  getEl('new-pass').value = '';
  getEl('confirm-pass').value = '';
}

function importWallet() {
  var seed = getEl('import-seed-input').value.trim();
  var pass = getEl('import-pass').value;
  if (seed.split(' ').length !== 12) { alert('Invalid seed (must be 12 words)'); return; }
  if (pass.length < 4) { alert('Password too short'); return; }
  
  var baseAddr = 'XOS' + Math.random().toString(36).substring(2, 10).toUpperCase();
  var newWallet = {
    id: Date.now().toString(),
    name: 'Imported ' + (wallets.length + 1),
    baseSeed: seed,
    addresses: {
      'xos-main': baseAddr,
      'xos-test': 't' + baseAddr,
      'eth-main': '0x' + baseAddr.toLowerCase(),
      'bsc-main': '0x' + baseAddr.toLowerCase()
    },
    balances: {},
    txsByNet: {}
  };
  getWalletBalances(newWallet);

  wallets.push(newWallet);
  currentWalletId = newWallet.id;
  saveData();
  updateDashboard();
  showScreen('dashboard-screen');
  getEl('import-seed-input').value = '';
  getEl('import-pass').value = '';
}

function deleteWallet() {
  if (wallets.length <= 1) { alert('Cannot delete the only wallet!'); return; }
  if (!confirm('Are you sure? This cannot be undone.')) return;
  var newWallets = [];
  for (var i = 0; i < wallets.length; i++) {
    if (wallets[i].id !== currentWalletId) newWallets.push(wallets[i]);
  }
  wallets = newWallets;
  currentWalletId = wallets[0].id;
  saveData();
  updateDashboard();
}

function updateDashboard() {
  var wallet = null;
  for (var i = 0; i < wallets.length; i++) {
    if (wallets[i].id === currentWalletId) { wallet = wallets[i]; break; }
  }
  if (!wallet) return;

  // Update Wallet Selector
  var selector = getEl('wallet-selector');
  selector.innerHTML = '';
  for (var j = 0; j < wallets.length; j++) {
    var w = wallets[j];
    var opt = document.createElement('option');
    opt.value = w.id;
    opt.innerText = w.name;
    if (w.id === currentWalletId) opt.selected = true;
    selector.appendChild(opt);
  }

  // Update Network Specific Data
  var balance = getWalletBalances(wallet);
  var addr = wallet.addresses[currentNetwork] || 'Unknown';
  
  getEl('address-display').innerText = addr;
  getEl('balance-display').innerText = balance.toFixed(4);
  
  // Update History
  var txs = wallet.txsByNet[currentNetwork] || [];
  var list = getEl('tx-list');
  list.innerHTML = '';
  if (txs.length === 0) {
    list.innerHTML = '<li style="text-align:center;color:var(--sub);font-size:12px;padding:10px">No transactions on ' + networks[currentNetwork].name + '</li>';
  } else {
    for (var k = txs.length - 1; k >= 0; k--) {
      var tx = txs[k];
      var li = document.createElement('li');
      li.className = 'tx-item';
      var sign = (tx.type === 'Sent') ? '-' : '+';
      li.innerHTML = '<div class="tx-head"><span>' + tx.type + '</span><span>' + sign + tx.amount + ' ' + networks[currentNetwork].symbol + '</span></div><div class="tx-det"><span>' + (tx.to || 'Received') + '</span><span>' + new Date(tx.date).toLocaleTimeString() + '</span></div>';
      list.appendChild(li);
    }
  }
}

function showReceiveScreen() {
  showScreen('receive-screen');
  var wallet = null;
  for (var i = 0; i < wallets.length; i++) {
    if (wallets[i].id === currentWalletId) { wallet = wallets[i]; break; }
  }
  if(!wallet) return;
  
  var addr = wallet.addresses[currentNetwork];
  getEl('receive-addr').innerText = addr;
  
  // Generate QR
  getEl('qrcode').innerHTML = '';
  if (typeof QRCode !== 'undefined') {
    new QRCode(getEl('qrcode'), {
      text: addr,
      width: 180,
      height: 180,
      colorDark : "#000000",
      colorLight : "#ffffff",
      correctLevel : QRCode.CorrectLevel.H
    });
  } else {
    getEl('qrcode').innerText = "QR Library Loading...";
  }
}

function copyAddress() {
  var wallet = null;
  for (var i = 0; i < wallets.length; i++) {
    if (wallets[i].id === currentWalletId) { wallet = wallets[i]; break; }
  }
  var addr = wallet.addresses[currentNetwork];
  navigator.clipboard.writeText(addr).then(function() { alert('Address Copied!'); });
}

function copyReceiveAddress() {
  copyAddress();
}

function sendTransaction() {
  var to = getEl('send-to').value;
  var amtVal = getEl('send-amt').value;
  var amt = parseFloat(amtVal);
  
  var wallet = null;
  for (var i = 0; i < wallets.length; i++) {
    if (wallets[i].id === currentWalletId) { wallet = wallets[i]; break; }
  }
  
  var balance = getWalletBalances(wallet);

  if (!to || !amt || amt <= 0) { alert('Invalid details'); return; }
  if (amt > balance) { alert('Insufficient balance on ' + networks[currentNetwork].name); return; }

  // Update Balance
  wallet.balances[currentNetwork] -= amt;
  wallet.txsByNet[currentNetwork].push({ type: 'Sent', amount: amt, to: to, date: Date.now() });

  // Simulate Reward
  setTimeout(function() {
    wallet.balances[currentNetwork] += (amt * 0.05);
    wallet.txsByNet[currentNetwork].push({ type: 'Received', amount: (amt * 0.05), to: 'Faucet', date: Date.now() });
    saveData();
    updateDashboard();
    alert('Transaction Successful on ' + networks[currentNetwork].name + '!');
    getEl('send-to').value = '';
    getEl('send-amt').value = '';
  }, 1000);

  saveData();
  updateDashboard();
}
